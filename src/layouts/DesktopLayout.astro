---
import LeftMenu from "../components/LeftMenu.astro";
import RightPageInfo from "../components/RightPageInfo.astro";
import Footer from "../components/Footer.astro";

interface Props {
  currentPath: string;
  pageName: string;
  pageId: string;
}
const { currentPath, pageName, pageId } = Astro.props;
---

<div class="desktop-layout">
  <div class="desktop-grid">
    <LeftMenu currentPath={currentPath} />
    <div class="desktop-main">
      <slot />
    </div>
    <RightPageInfo text={pageName} id={pageId} />
  </div>
  <Footer />
</div>

<script>
  import "../scripts/pageFadeIn";
</script>

<style lang="scss">
  @use "../styles/tokens" as *;
  @use "../styles/mixins" as *;

  .desktop-layout {
    min-height: 100vh;
    padding-bottom: $footerHeight;
    position: relative;
  }

  .desktop-grid {
    display: grid;
    grid-template-columns: 1fr 8fr 1fr;
    min-height: calc(100vh - #{$footerHeight});
  }

  .desktop-main {
    padding-top: 5vh;
    max-width: $desktopContentMaxWidth;
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    color: var(--textColor);
  }

  @include mobile {
    .desktop-layout {
      display: none;
    }
  }
</style>
