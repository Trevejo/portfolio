---
import BaseLayout from "../layouts/BaseLayout.astro";
import DesktopLayout from "../layouts/DesktopLayout.astro";
import MobileLayout from "../layouts/MobileLayout.astro";

const pageName = "Home";
const pageId = "01";
const currentPath = Astro.url.pathname;
---

<BaseLayout title="Trevejo">
  <DesktopLayout currentPath={currentPath} pageName={pageName} pageId={pageId}>
    <div class="card" data-fade-in>Theme + layout ok (desktop).</div>
  </DesktopLayout>
  <MobileLayout title={pageName}>
    <div class="card" data-fade-in>Theme + layout ok (mobile).</div>
  </MobileLayout>
</BaseLayout>

<style lang="scss">
  @use "../styles/tokens" as *;

  .card {
    padding: $l;
    border: 1px solid var(--black);
    text-align: center;
    font-size: $fontM;
    line-height: 150%;
  }
</style>
