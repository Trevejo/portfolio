---
import "../styles/global.scss";
import ThemeToggle from "../components/ThemeToggle.astro";
---

<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Trevejo</title>
  </head>
  <body>
    <div class="layout">
      <div class="theme-slot">
        <ThemeToggle />
      </div>
      <div class="placeholder">
        <h1>Trevejo</h1>
        <p>Theme foundation ok.</p>
      </div>
    </div>
  </body>
</html>

<style lang="scss">
  @use "../styles/tokens" as *;

  .layout {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
  }

  .theme-slot {
    position: absolute;
    top: $s;
    right: $s;
    z-index: 10;
  }

  .placeholder {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: $s;
  }
</style>
