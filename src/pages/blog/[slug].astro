---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DesktopLayout from "../../layouts/DesktopLayout.astro";
import MobileLayout from "../../layouts/MobileLayout.astro";
import { getCollection, render } from "astro:content";
import { findRouteByPath } from "../../constants/routes";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
  timeZone: "UTC",
});
const currentPath = Astro.url.pathname;
const route = findRouteByPath(currentPath);
const pageName = route ?? "Blog";
const pageId = "03";
---

<BaseLayout
  title={`${post.data.title} — Trevejo`}
  description={post.data.description}
>
  <DesktopLayout
    currentPath={currentPath}
    pageName={pageName}
    pageId={pageId}
  >
    <article class="blog-post" data-fade-in>
      <header class="post-header">
        <h1 class="post-title">{post.data.title}</h1>
        <time class="post-date" datetime={post.data.date.toISOString()}>
          {formattedDate}
        </time>
      </header>
      <div class="post-content">
        <Content />
      </div>
    </article>
  </DesktopLayout>
  <MobileLayout title="Blog">
    <article class="blog-post" data-fade-in>
      <header class="post-header">
        <h1 class="post-title">{post.data.title}</h1>
        <time class="post-date" datetime={post.data.date.toISOString()}>
          {formattedDate}
        </time>
      </header>
      <div class="post-content">
        <Content />
      </div>
      <a class="back-to-blog" href={`${import.meta.env.BASE_URL}/blog`}>
        ← All posts
      </a>
    </article>
  </MobileLayout>
</BaseLayout>

<style lang="scss">
  @use "../../styles/tokens" as *;
  @use "../../styles/typo" as *;
  @use "../../styles/mixins" as *;

  .blog-post {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 $s;
    box-sizing: border-box;
  }

  .post-header {
    max-width: 800px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: $l;
  }

  .post-title {
    font-size: $fontXXL;
    line-height: 150%;
    font-weight: 700;
    color: var(--textColor);
    margin: 0 0 $xs;
  }

  .post-date {
    font-size: $fontS;
    line-height: 150%;
    opacity: 0.75;
    color: var(--textColor);
  }

  .post-content {
    max-width: 800px;
    width: 100%;
    font-size: $fontM;
    line-height: 150%;
    color: var(--textColor);
    word-wrap: break-word;
  }

  .post-content :global(h1) {
    font-size: $fontXXL;
    line-height: 150%;
    margin: $m 0 $s;
  }

  .post-content :global(h2) {
    font-size: $fontXL;
    line-height: 150%;
    margin: $l 0 $s;
  }

  .post-content :global(h3) {
    font-size: $fontL;
    line-height: 150%;
    margin: $l 0 $s;
  }

  .post-content :global(p),
  .post-content :global(ul),
  .post-content :global(ol),
  .post-content :global(pre),
  .post-content :global(img),
  .post-content :global(blockquote),
  .post-content :global(table),
  .post-content :global(hr) {
    margin: 0 0 1em;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    padding-left: $s;
    list-style: revert;
  }

  .post-content :global(ul li),
  .post-content :global(ol li) {
    list-style: inherit;
    margin: 0 0 $xs;
  }

  .post-content :global(a) {
    @extend %underline;
    color: var(--textColor);
  }

  .post-content :global(code) {
    padding: 1px 4px;
    border-radius: 4px;
    color: var(--codeColor);
    background: var(--codeBackground);
    border: var(--codeBorder);
    font-family: "Roboto Mono", monospace;
    font-size: 0.9em;
  }

  .post-content :global(pre.astro-code) {
    background-color: var(--codeBackground) !important;
    padding: $s;
    border: var(--codeBorder);
    border-radius: 0;
    overflow-x: auto;
    font-family: "Roboto Mono", monospace;
    font-size: $fontS;
    line-height: 150%;
  }

  .post-content :global(pre.astro-code code) {
    padding: 0;
    background: transparent;
    border: none;
    color: inherit;
    font-size: inherit;
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: $s;
    opacity: 0.85;
  }

  .post-content :global(img) {
    max-width: 100%;
    height: auto;
  }

  .post-content :global(hr) {
    border: 0;
    border-top: 1px solid var(--black);
    opacity: 0.3;
  }

  .back-to-blog {
    display: none;
    margin-top: $xl;
    font-size: $fontS;
    line-height: 150%;
    @extend %underlineS;
    color: var(--textColor);
  }

  @include mobile {
    .post-title {
      font-size: $fontL;
    }

    .back-to-blog {
      display: inline-block;
    }
  }
</style>
