---
import ThemeToggle from "./ThemeToggle.astro";
import { ROUTES } from "../constants/routes";

interface Props {
  title: string;
}
const { title } = Astro.props;
const homeLink = ROUTES.find((r) => r.name === "Home")!.link;
---

<div class="topbar">
  <div class="topbar-col topbar-left">
    <ThemeToggle />
  </div>
  <div class="topbar-col topbar-center">
    <a href={homeLink} class="topbar-title">{title}</a>
  </div>
  <div class="topbar-col topbar-right"></div>
</div>

<style lang="scss">
  @use "../styles/tokens" as *;

  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: $burgerMenuHeight;
    background: var(--background);
    border-bottom: 1px solid var(--black);
    display: flex;
    align-items: center;
    z-index: 10;
    color: var(--textColor);
  }

  .topbar-col {
    flex: 1;
    display: flex;
    align-items: center;
    height: 100%;
  }

  .topbar-left {
    justify-content: flex-start;
    padding-left: $s;
  }

  .topbar-center {
    justify-content: center;
  }

  .topbar-right {
    justify-content: flex-end;
  }

  .topbar-title {
    font-size: $fontS;
    line-height: 150%;
    color: var(--textColor);
    text-decoration: none;
  }

  @media (min-width: 1101px) {
    .topbar {
      display: none;
    }
  }
</style>
