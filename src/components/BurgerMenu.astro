---
import { ROUTES, findRouteByPath } from "../constants/routes";

const currentName = findRouteByPath(Astro.url.pathname);
---

<button
  class="burger-icon"
  id="burger-icon"
  type="button"
  aria-label="Menu"
  aria-expanded="false"
>
  <span class="bar bar-top"></span>
  <span class="bar bar-mid"></span>
  <span class="bar bar-bot"></span>
</button>
<aside class="burger-menu" id="burger-menu" aria-hidden="true">
  <nav aria-label="Mobile">
    <ul class="burger-list">
      {
        ROUTES.map((r) => (
          <li class="burger-item">
            <a
              href={r.link}
              data-route={r.id}
              class:list={["burger-link", { current: r.name === currentName }]}
            >
              {r.name}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</aside>

<script>
  function init(): void {
    const btn = document.getElementById("burger-icon");
    const menu = document.getElementById("burger-menu");
    if (!btn || !menu) return;

    if (btn.dataset.bound === "true") {
      document.body.classList.remove("burgerMenuOpen");
      btn.setAttribute("aria-expanded", "false");
      menu.setAttribute("aria-hidden", "true");
      return;
    }
    btn.dataset.bound = "true";

    function getFocusables(): HTMLElement[] {
      return Array.from(
        menu!.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])',
        ),
      );
    }

    function trapFocus(e: KeyboardEvent): void {
      if (e.key !== "Tab") return;
      if (!document.body.classList.contains("burgerMenuOpen")) return;
      const focusables = getFocusables();
      if (focusables.length === 0) return;
      const first = focusables[0];
      const last = focusables[focusables.length - 1];
      const active = document.activeElement;
      if (e.shiftKey && active === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && active === last) {
        e.preventDefault();
        first.focus();
      }
    }

    function onKeyDown(e: KeyboardEvent): void {
      if (e.key === "Escape" && document.body.classList.contains("burgerMenuOpen")) {
        e.preventDefault();
        setOpen(false);
        return;
      }
      trapFocus(e);
    }

    function setOpen(open: boolean): void {
      document.body.classList.toggle("burgerMenuOpen", open);
      btn!.setAttribute("aria-expanded", String(open));
      menu!.setAttribute("aria-hidden", String(!open));
      if (open) {
        const focusables = getFocusables();
        if (focusables[0]) {
          window.setTimeout(() => focusables[0].focus(), 50);
        }
      } else {
        btn!.focus();
      }
    }

    btn.addEventListener("click", () => {
      const isOpen = document.body.classList.contains("burgerMenuOpen");
      setOpen(!isOpen);
    });

    menu.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", () => setOpen(false));
    });

    document.addEventListener("keydown", onKeyDown);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init, { once: true });
  } else {
    init();
  }

  document.addEventListener("astro:page-load", init);
</script>

<style lang="scss">
  @use "../styles/tokens" as *;

  .burger-icon {
    --burger-duration: 250ms;
    position: fixed;
    top: 0;
    right: 0;
    width: 58px;
    height: $burgerMenuHeight;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--textColor);
  }

  .bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--black);
    transition: transform var(--burger-duration) ease-out,
      opacity var(--burger-duration) ease-out;
  }

  :global(body.burgerMenuOpen) .bar-top {
    transform: rotate(26deg) scaleX(0.7);
  }

  :global(body.burgerMenuOpen) .bar-bot {
    transform: rotate(-26deg) scaleX(0.7);
  }

  :global(body.burgerMenuOpen) .bar-mid {
    opacity: 0;
  }

  .burger-menu {
    --burger-duration: 250ms;
    position: fixed;
    inset: 0;
    background: var(--background);
    border-left: 1px solid var(--black);
    transform: translateX(100%);
    transition: transform var(--burger-duration) ease-out;
    z-index: 30;
    color: var(--textColor);
  }

  :global(body.burgerMenuOpen) .burger-menu {
    transform: translateX(0);
  }

  .burger-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .burger-item {
    margin: 0;
    padding: 0;
  }

  .burger-link {
    display: block;
    padding: $s $m;
    font-size: $fontM;
    line-height: 150%;
    color: var(--textColor);
    text-decoration: none;
  }

  .burger-link.current {
    background: var(--accent);
    width: 150px;
  }

  nav {
    padding-top: $burgerMenuHeight;
  }

  @media (min-width: 1101px) {
    .burger-icon,
    .burger-menu {
      display: none;
    }
  }
</style>
