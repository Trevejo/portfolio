---
import { ROUTES, findRouteByPath } from "../constants/routes";

interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;
const currentName = findRouteByPath(currentPath);
---

<aside class="left-menu">
  <div class="left-menu-frame" id="left-menu-frame"></div>
  <nav aria-label="Primary">
    <ul class="nav-list" id="nav-list">
      {
        ROUTES.map((r) => (
          <li>
            <a
              href={r.link}
              data-route={r.id}
              class:list={["nav-link", { current: r.name === currentName }]}
            >
              {r.name}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
  <div class="nav-pointer" id="nav-pointer"></div>
</aside>

<script>
  function init(): void {
    const list = document.getElementById("nav-list");
    const pointer = document.getElementById("nav-pointer");

    function moveToLink(target: HTMLElement): void {
      if (!list || !pointer) return;
      const listRect = list.getBoundingClientRect();
      const targetRect = target.getBoundingClientRect();
      const y = targetRect.top - listRect.top;
      pointer.style.transform = `translateY(${y}px)`;
    }

    function initPointer(): void {
      if (!list || !pointer) return;
      const current = list.querySelector<HTMLElement>("a.current");
      if (current) {
        moveToLink(current);
        pointer.classList.add("is-current");
      } else {
        pointer.classList.remove("is-current");
      }
    }

    if (!list || !pointer) return;
    if (list.dataset.bound === "true") {
      initPointer();
      return;
    }
    list.dataset.bound = "true";

    initPointer();
    window.addEventListener("resize", initPointer);

    list.querySelectorAll<HTMLElement>("a").forEach((a) => {
      a.addEventListener("click", () => moveToLink(a));
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init, { once: true });
  } else {
    init();
  }

  document.addEventListener("astro:page-load", init);
</script>

<style lang="scss">
  @use "../styles/tokens" as *;
  @use "../styles/mixins" as *;

  .left-menu {
    position: relative;
    min-width: 120px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: $s;
    color: var(--textColor);
  }

  .left-menu-frame {
    display: none;
  }

  .nav-list {
    position: relative;
    list-style: none;
    margin: 0;
    padding: 0;
    z-index: 1;
  }

  .nav-list li {
    margin: 0;
    padding: 0;
  }

  .nav-link {
    display: block;
    padding: $xs 0;
    font-family: "Roboto Mono", monospace;
    font-size: $fontS;
    line-height: 150%;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--textColor);
    text-decoration: none;
  }

  .nav-link.current {
    font-weight: 700;
    color: var(--accent);
  }

  .nav-pointer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 35px;
    background: var(--accent);
    border: 1px solid var(--black);
    opacity: 0.15;
    pointer-events: none;
    transition: transform 250ms ease-out, opacity 150ms ease-out;
    z-index: 0;
  }

  .left-menu:hover .nav-pointer {
    opacity: 0.4;
  }

  .nav-pointer.is-current {
    opacity: 1;
  }

  @include mobile {
    .left-menu {
      display: none;
    }
  }
</style>
